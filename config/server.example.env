# Copy this file to `server.env` (Compose) or feed it into a Kubernetes
# Secret. Every value below overrides the matching key in defaults.env.
#
# Compose:    cp server.example.env server.env  → referenced from env_file
# Kubernetes: see k8s/secret.example.yaml

# ─── Required ───────────────────────────────────────────────────────────────

# World password. Empty = public server. Pick something the server owner
# is willing to share in a Discord pinned post; the engine doesn't enforce
# complexity rules and there's no separate admin password yet.
PASSWORD=changeme

# ─── Server identity ────────────────────────────────────────────────────────

# Auto-load this saved world by name. Leave empty to use the auto-create flow
# below — handy on first boot, then set the world name once it's been saved.
AUTO_START_WORLD_NAME=

# If AUTO_START_WORLD_NAME is empty, the engine will create one with these
# parameters on first boot:
AUTO_CREATE_AND_LOAD_WORLD=true
AUTO_CREATE_WORLD_SIZE=1            # 1 = small, 2 = medium, 3 = large
AUTO_CREATE_WORLD_SEED=null         # null = random; quote a string for fixed

# ─── Slots + ports ──────────────────────────────────────────────────────────
PORT=8050
MAX_PLAYERS=8

# ─── Admin / cheats ─────────────────────────────────────────────────────────
ENABLE_CHEATS=false                 # set true only for test servers

# ─── Steam auth (only if anonymous downloads break) ─────────────────────────
# Anonymous works today (2026-05). If DepotDownloader starts returning
# "Access denied" against app 4763510, switch to an owning account:
#
#   STEAM_USER=<your-steam-login>
#   STEAM_PASSWORD=<password>
#   STEAM_GUARD_CODE=<Steam-Guard-code-on-first-run-only>
#
# On first run the session token is cached in INSTALL_DIR/.DepotDownloader
# and subsequent runs reuse it (you can clear STEAM_PASSWORD afterwards).

# ─── Branch toggle ──────────────────────────────────────────────────────────
# Romestead currently has no public beta channel. Plumbing is here for the
# day it does — leave as `public` unless the game adds one.
BRANCH=public
# BRANCH_PASSWORD=

# ─── Lifecycle / maintenance ────────────────────────────────────────────────
UPDATE_ON_START=true                # re-validate depot on every start
STOP_GRACE_SECONDS=30               # how long to wait for clean shutdown
GENERATE_SETTINGS=true              # false = preserve hand-edits to config.json

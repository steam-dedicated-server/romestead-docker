# Baked-into-image defaults for the Romestead dedicated server.
# Overridden by /mnt/steam/server.env (if present), then by the shell env.
# Operators should not edit this file — use config/server.env or compose
# env_file / K8s Secret instead.

# ── Steam / depot ───────────────────────────────────────────────────────────
STEAM_APP_ID=4763510
STEAM_USER=anonymous
BRANCH=public

# ── Paths ───────────────────────────────────────────────────────────────────
INSTALL_DIR=/mnt/steam/server-files
BACKUP_DIR=/mnt/steam/backups
SAVE_SUBDIR=Worlds

# ── Server lifecycle ────────────────────────────────────────────────────────
UPDATE_ON_START=true
STOP_GRACE_SECONDS=30
GENERATE_SETTINGS=true

# ── In-game config (rendered into <INSTALL_DIR>/config.json) ────────────────
AUTO_START_WORLD_NAME=
AUTO_CREATE_AND_LOAD_WORLD=true
AUTO_CREATE_WORLD_SIZE=1
AUTO_CREATE_WORLD_SEED=null
PASSWORD=
PORT=8050
MAX_PLAYERS=8
ENABLE_CHEATS=false

# ── Retry behavior for DepotDownloader ──────────────────────────────────────
RS_RETRY_MAX=5
RS_RETRY_DELAY=5
